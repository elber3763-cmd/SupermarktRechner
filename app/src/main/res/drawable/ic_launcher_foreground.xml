<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Scaled group to make icon larger and centered -->
    <group
        android:translateX="54"
        android:translateY="54"
        android:scaleX="2.8"
        android:scaleY="2.8">

        <!-- Scanner Frame (rounded rectangle) -->
        <path
            android:fillColor="@android:color/transparent"
            android:pathData="M -14,-12 Q -16,-12 -16,-10 L -16,6 Q -16,8 -14,8 L 14,8 Q 16,8 16,6 L 16,-10 Q 16,-12 14,-12 L -14,-12 Z"
            android:strokeColor="@android:color/white"
            android:strokeWidth="0.9"
            android:strokeLineJoin="round" />

        <!-- Camera Lens Circle (center) -->
        <path
            android:fillColor="@android:color/transparent"
            android:pathData="M -7,-4 C -7,-7.3 -4,-10 0,-10 C 4,-10 7,-7.3 7,-4 C 7,0.6 4,4 0,4 C -4,4 -7,0.6 -7,-4 Z"
            android:strokeColor="@android:color/white"
            android:strokeWidth="0.9"
            android:strokeLineJoin="round" />

        <!-- Inner lens highlight -->
        <path
            android:fillColor="@android:color/white"
            android:fillAlpha="0.15"
            android:pathData="M -5,-4 C -5,-6.3 -2.9,-8 0,-8 C 2.9,-8 5,-6.3 5,-4 C 5,-1.7 2.9,0 0,0 C -2.9,0 -5,-1.7 -5,-4 Z" />

        <!-- Scan lines below lens -->
        <path
            android:strokeColor="@android:color/white"
            android:strokeWidth="0.55"
            android:strokeLineCap="round"
            android:fillColor="@android:color/transparent"
            android:pathData="M -10,4 L 10,4" />

        <path
            android:strokeColor="@android:color/white"
            android:strokeWidth="0.55"
            android:strokeLineCap="round"
            android:fillColor="@android:color/transparent"
            android:pathData="M -10,5.5 L 10,5.5" />

        <!-- Shopping Cart (top-right accent) -->
        <!-- Cart body -->
        <path
            android:fillColor="@android:color/transparent"
            android:pathData="M 10,-10 L 12,-7.5 L 8,-6.5 Z"
            android:strokeColor="@android:color/white"
            android:strokeWidth="0.65"
            android:strokeLineJoin="round"
            android:strokeLineCap="round" />

        <!-- Cart handle -->
        <path
            android:fillColor="@android:color/transparent"
            android:pathData="M 10,-10 Q 11,-13 15,-11.5"
            android:strokeColor="@android:color/white"
            android:strokeWidth="0.55"
            android:strokeLineCap="round" />

        <!-- Left wheel -->
        <path
            android:fillColor="@android:color/white"
            android:pathData="M 8,-6.5 C 8,-5.8 7.6,-5.2 7,-5.2 C 6.4,-5.2 6,-5.8 6,-6.5 C 6,-7.2 6.4,-7.8 7,-7.8 C 7.6,-7.8 8,-7.2 8,-6.5 Z" />

        <!-- Right wheel -->
        <path
            android:fillColor="@android:color/white"
            android:pathData="M 12,-6.5 C 12,-5.8 11.6,-5.2 11,-5.2 C 10.4,-5.2 10,-5.8 10,-6.5 C 10,-7.2 10.4,-7.8 11,-7.8 C 11.6,-7.8 12,-7.2 12,-6.5 Z" />

    </group>

</vector>
